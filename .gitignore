# ------------------------
# Python / Django
# ------------------------

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Django migrations
# */migrations/*.py
# */migrations/*.pyc

# Django stuff:
*.log
local_settings.py
db.sqlite3

# Python virtual environment folders
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# ------------------------
# Node / Next.js / React
# ------------------------

# Node modules
node_modules/

# Next.js build output
.next/

# Next.js cache
.cache/

# Build output
out/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------
# PostgreSQL
# ------------------------

# Ignore local database data directory if any (adjust if you keep it locally)
pgdata/
*.pgsql

# ------------------------
# Nginx
# ------------------------

# Nginx logs (adjust if your logs directory is different)
logs/
*.log

# ------------------------
# IDE / Editor configs
# ------------------------

.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ------------------------
# Misc
# ------------------------

.DS_Store
Thumbs.db
